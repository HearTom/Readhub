# Mismas credenciales que apps/web/.env.local (proyecto Supabase compartido).
# Este servidor usa la clave anon (no la service role) -- solo lee contenido
# público de ReadHub, respetando las mismas políticas RLS que ve cualquier
# visitante no autenticado.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Hugging Face Inference API -- requerido por las Tools de búsqueda semántica
# y RAG (@readhub/ai / @readhub/database/vector-search.service /
# @readhub/database/chat.service).
HF_TOKEN=your-huggingface-token
