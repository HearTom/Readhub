# Supabase — URL del proyecto y clave anon (seguras para exponer en el navegador)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — secreta, solo para uso en el servidor
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hugging Face Inference API — embeddings (sentence-transformers/all-MiniLM-L6-v2)
# y, en fases posteriores, generación conversacional (meta-llama/Llama-3.1-8B-Instruct).
# Solo se lee server-side (services/embedding.service.ts vía lib/ai/).
HF_TOKEN=your-huggingface-token

# Usuario QA para los E2E de autenticación (e2e/auth.spec.ts). Debe ser un
# usuario real, ya confirmado, en el proyecto Supabase contra el que corre la
# suite — nunca se commitea con un valor real (.env.local está en .gitignore).
E2E_USER_EMAIL=e2e-user@example.com
E2E_USER_PASSWORD=change-me
